{% extends "layouts/layout.twig" %}

{% block content %}
<section class="normal-breadcrumb set-bg" data-setbg="/img/normal-breadcrumb.jpg">
    <div class="container">
        <div class="row">
            <div class="col-lg-12 text-center">
                <div class="normal__breadcrumb__text">
                    <h2>Fiókom</h2>
                    <p>Itt látod az alapvető fiókadataidat.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="signup spad">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="login__form">
                    <h3>Bejelentkezett felhasználó</h3>

                    <div class="alert alert-success" role="alert">
                        Sikeresen be vagy jelentkezve.
                    </div>

                    <div class="mb-4">
                        <p class="mb-2"><strong>Név:</strong> {{ auth.user.name }}</p>
                        <p class="mb-2"><strong>Felhasználónév:</strong> {{ auth.user.username }}</p>
                        <p class="mb-2"><strong>E-mail:</strong> {{ auth.user.email }}</p>
                        <p class="mb-0"><strong>Felhasználó azonosító:</strong> {{ auth.user.id }}</p>
                    </div>

                    <p class="mb-4 text-white-50">
                        Ez most egy minimális, védett oldal. Később ide kerülhet például a profil,
                        a kedvencek, a watchlist vagy a saját értékelések kezelése.
                    </p>

                    <a href="/logout/" class="site-btn">Kijelentkezés</a>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}
